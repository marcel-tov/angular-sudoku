# Firebase Web App config — used by scripts/set-firebase-config.mjs to
# generate src/app/core/scan-dialog/firebase.config.ts at build time.
#
# Copy this file to `.env` for local development and fill in real values.
# On Netlify, set the same keys under:
#   Site settings → Build & deploy → Environment → Environment variables

FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
