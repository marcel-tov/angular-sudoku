    "cypress:run": "ng run angular-sudoku:cypress-run",
    "eslint": "eslint --cache '**/*.{js,ts,html}'",
    "stylelint": "stylelint --cache 'src/**/*.scss'",
    "lint": "npm run eslint -- --quiet && npm run stylelint",
    "test": "ng test",
    "test:watch": "ng test --watch",
    "test:ci": "ng test --configuration=ci",
    "fmt": "npm run eslint -- --fix && npm run stylelint -- --fix",
    "semantic-release": "semantic-release"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^21.2.9",
    "@angular/cdk": "^21.2.9",
    "@angular/common": "^21.2.9",
