{
  "name": "angular-sudoku",
  "version": "1.14.0",
  "scripts": {
    "ng": "ng",
    "set-firebase-config": "node scripts/set-firebase-config.mjs",
    "prestart": "npm run set-firebase-config",
    "start": "ng serve",
    "prebuild": "npm run set-firebase-config",
    "build": "ng build",
    "cypress:e2e": "ng e2e",
    "cypress:e2e:firefox": "ng run angular-sudoku:e2e:firefox",
