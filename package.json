    "@angular/forms": "^21.2.9",
    "@angular/material": "^21.2.9",
    "@angular/platform-browser": "^21.2.9",
    "@angular/router": "^21.2.11",
    "core-js": "3.49.0",
    "firebase": "^12.12.0",
    "rxjs": "7.8.2",
    "tslib": "2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/architect": "0.2102.7",
