{
  "include": ["**/*.ts"],
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "dom"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "useDefineForClassFields": false,
    "importHelpers": true,
    "skipLibCheck": true,
    "sourceMap": false,
    "types": ["cypress"],
    "rootDir": ".",
    "noEmit": true
  }
}
